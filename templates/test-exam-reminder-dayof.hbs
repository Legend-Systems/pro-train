<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Today: {{testTitle}}</title>
    <style>
        body { margin: 0; padding: 0; background: #f1f5f9; color: #1f2937; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
        .wrap { max-width: 600px; margin: 0 auto; background: #ffffff; }
        .header { background: linear-gradient(135deg, #413DFB 0%, #A17EFA 100%); padding: 28px 24px; text-align: center; color: #fff; }
        .logo { max-height: 48px; margin-bottom: 12px; }
        .content { padding: 28px 24px; }
        .card { background: #f8fafc; border-radius: 12px; padding: 18px; margin: 18px 0; border-left: 4px solid #413DFB; }
        .urgent { background: #fee2e2; border-left-color: #dc2626; }
        .label { font-size: 12px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em; }
        .value { font-size: 16px; font-weight: 600; color: #111827; margin-top: 4px; }
        .cta { text-align: center; margin: 28px 0 12px; }
        .btn { display: inline-block; padding: 14px 24px; border-radius: 8px; text-decoration: none; font-weight: 700; margin: 6px; }
        .btn-primary { background: #dc2626; color: #ffffff !important; }
        .btn-secondary { background: #ede9fe; color: #413DFB !important; }
        .footer { padding: 20px 24px; background: #f8fafc; text-align: center; font-size: 12px; color: #6b7280; }
        .company-logo { max-height: 28px; margin-top: 10px; opacity: 0.9; }
    </style>
</head>
<body>
    <div class="wrap">
        <div class="header">
            {{#if appLogoDataUri}}
            <img class="logo" src="{{appLogoDataUri}}" alt="ProTrain" />
            {{else}}
            <h1 style="margin:0;">ProTrain</h1>
            {{/if}}
            <p style="margin:8px 0 0; opacity:0.95;">Exam day — take your test today</p>
        </div>
        <div class="content">
            <p>Hi {{recipientName}},</p>
            <p><strong>Today is exam day.</strong> Please open ProTrain and complete your test as soon as you can.</p>

            <div class="card urgent">
                <div class="label">Action required today</div>
                <div class="value">{{testTitle}}</div>
                <div style="height:12px"></div>
                <div class="label">Course</div>
                <div class="value">{{courseTitle}}</div>
                <div style="height:12px"></div>
                <div class="label">Exam date</div>
                <div class="value">{{formattedExamDate}}</div>
            </div>

            <div class="cta">
                <a class="btn btn-primary" href="{{takeTestUrl}}">Take Test Now</a>
                <a class="btn btn-secondary" href="{{openAppUrl}}">Open ProTrain App</a>
            </div>
            <p style="font-size:13px;color:#6b7280;text-align:center;">
                Prefer the mobile app? Use Open ProTrain App, or this deep link:<br />
                <a href="{{deepLinkUrl}}">{{deepLinkUrl}}</a>
            </p>
        </div>
        <div class="footer">
            {{#if companyLogoDataUri}}
            <img class="company-logo" src="{{companyLogoDataUri}}" alt="Company" />
            {{/if}}
            {{#if appIconDataUri}}
            <div><img class="company-logo" src="{{appIconDataUri}}" alt="PT" /></div>
            {{/if}}
            <p>{{companyName}}</p>
            <p><a href="{{unsubscribeUrl}}">Notification settings / unsubscribe</a></p>
            <p>Need help? <a href="mailto:{{supportEmail}}">{{supportEmail}}</a></p>
        </div>
    </div>
</body>
</html>
