<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{reportTitle}}</title>
    <style>
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #f8fafc; color: #1f2937; margin: 0; }
        .container { max-width: 640px; margin: 0 auto; background: #fff; border-radius: 8px; overflow: hidden; }
        .header { background: linear-gradient(135deg, #A17EFA 0%, #413DFB 100%); color: #fff; padding: 32px 24px; text-align: center; }
        .content { padding: 24px; }
        .kpi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 16px 0; }
        .kpi { background: #f8fafc; border-radius: 8px; padding: 12px; }
        .kpi-label { font-size: 12px; color: #6b7280; }
        .kpi-value { font-size: 20px; font-weight: 700; color: #111827; }
        ul { padding-left: 18px; }
        .footer { padding: 20px 24px; background: #f8fafc; font-size: 12px; color: #6b7280; text-align: center; }
        .badge { display: inline-block; background: #ede9fe; color: #5b21b6; border-radius: 999px; padding: 4px 10px; font-size: 12px; }
        .digest { background: linear-gradient(180deg, #f5f3ff 0%, #f8fafc 100%); border: 1px solid #ede9fe; border-radius: 10px; padding: 16px; margin: 20px 0; }
        .digest h3 { margin-top: 0; color: #413DFB; }
        .digest h4 { margin-bottom: 6px; color: #4c1d95; }
        .celebrate { font-size: 15px; font-weight: 600; color: #111827; margin-bottom: 12px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>{{reportTitle}}</h1>
            <p>ProTrain admin training insights</p>
            <p class="badge">{{timeframe}} · {{generatedAt}}</p>
        </div>
        <div class="content">
            <p>Hi {{recipientName}},</p>
            <p>Here is your latest organization training performance summary{{#if organizationName}} for <strong>{{organizationName}}</strong>{{/if}}.</p>

            <div class="kpi-grid">
                <div class="kpi"><div class="kpi-label">Avg knowledge score</div><div class="kpi-value">{{averageKnowledgeScore}}%</div></div>
                <div class="kpi"><div class="kpi-label">Pass rate</div><div class="kpi-value">{{overallPassRate}}%</div></div>
                <div class="kpi"><div class="kpi-label">Active learners</div><div class="kpi-value">{{activeLearners}}</div></div>
                <div class="kpi"><div class="kpi-label">Training hours</div><div class="kpi-value">{{totalTrainingHours}}h</div></div>
            </div>

            <p><strong>Attention:</strong> {{atRiskUserCount}} at-risk users · {{keyAreaCount}} key training areas · {{highPotentialUserCount}} high-potential learners</p>

            {{#if topPerformersSummary.length}}
            <h3>Top performers</h3>
            <ul>
                {{#each topPerformersSummary}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
            {{/if}}

            {{#if keyAreasSummary.length}}
            <h3>Key areas needing training</h3>
            <ul>
                {{#each keyAreasSummary}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
            {{/if}}

            {{#if hasMotivationalDigest}}
            <div class="digest">
                <h3>Motivational digest</h3>
                {{#if celebrationHeadline}}
                <p class="celebrate">{{celebrationHeadline}}</p>
                {{/if}}

                {{#if hasLeaderboard}}
                <h4>Leaderboard shout-outs</h4>
                <ul>
                    {{#each leaderboardLines}}
                    <li>{{this}}</li>
                    {{/each}}
                </ul>
                {{/if}}

                {{#if hasRisingStars}}
                <h4>Rising stars</h4>
                <ul>
                    {{#each risingStarsLines}}
                    <li>{{this}}</li>
                    {{/each}}
                </ul>
                {{/if}}

                {{#if hasBranchChampions}}
                <h4>Branch champions</h4>
                <ul>
                    {{#each branchChampionLines}}
                    <li>{{this}}</li>
                    {{/each}}
                </ul>
                {{/if}}
            </div>
            {{/if}}

            {{#if hasCsv}}
            <p>A CSV summary is attached for deeper analysis.</p>
            {{/if}}
            {{#if hasPdf}}
            <p>A PDF report is attached for sharing with leadership.</p>
            {{/if}}
        </div>
        <div class="footer">
            {{#if companyName}}<div>{{companyName}}</div>{{/if}}
            <p>Need help? Contact <a href="mailto:{{supportEmail}}">{{supportEmail}}</a></p>
        </div>
    </div>
</body>
</html>
